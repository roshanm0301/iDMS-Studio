  "rules": [
    {
      "business_intent": "Every vehicle order must include at least one line item before it can be submitted.",
      "risk_mitigated": "Prevents empty orders from entering the approval workflow.",
      "layer": "platform",
      "enforcement_level": "BLOCK",
      "rule_json": {
        "id": "rule.vehicle_order.min_lines",
        "name": "Minimum Line Items Required",
        "entity_type": "vehicle_order",
        "trigger": "BEFORE_SUBMIT",
        "priority": 5,
        "enabled": true,
        "condition": {
          "op": "LT",
          "left": {
            "path": "vehicle_order.line_items.length"
          },
          "right": {
            "value": 1
          }
        },
        "action": {
          "type": "BLOCK",
          "message": "Vehicle order must have at least one line item before submission."
        }
      }
    },
    {
      "business_intent": "Automotive vehicle orders must identify the vehicle model before submission.",
      "risk_mitigated": "Prevents unfulfillable orders without a vehicle model.",
      "layer": "vertical",
      "enforcement_level": "BLOCK",
      "rule_json": {
        "id": "rule.vehicle_order.vehicle_model_required",
        "name": "Automotive Vehicle Model Required",
        "entity_type": "vehicle_order",
        "trigger": "BEFORE_SUBMIT",
        "priority": 10,
        "enabled": true,
        "condition": {
          "op": "IS_NULL",
          "left": {
            "path": "vehicle_order.vehicle_model"
          }
        },
        "action": {
          "type": "BLOCK",
          "message": "Vehicle model is required for automotive vehicle orders."
        }
      }
    },
    {
      "business_intent": "Bajaj vehicle orders must include the Bajaj dealer code before submission.",
      "risk_mitigated": "Prevents orders from being submitted without dealer attribution.",
      "layer": "tenant",
      "enforcement_level": "BLOCK",
      "rule_json": {
        "id": "rule.vehicle_order.bajaj_dealer_code_required",
        "name": "Bajaj Dealer Code Required",
        "entity_type": "vehicle_order",
        "trigger": "BEFORE_SUBMIT",
        "priority": 20,
        "enabled": true,
        "condition": {
          "op": "IS_NULL",
          "left": {
            "path": "vehicle_order.bajaj_dealer_code"
          }
        },
        "action": {
          "type": "BLOCK",
          "message": "Bajaj dealer code is required before submitting the order."
        }
      }
    },
    {
      "business_intent": "Bajaj vehicle orders must include GSTIN before submission.",
      "risk_mitigated": "Prevents tax compliance gaps in vehicle sales documents.",
      "layer": "tenant",
      "enforcement_level": "BLOCK",
      "rule_json": {
        "id": "rule.vehicle_order.gstin_required",
        "name": "GSTIN Required for Bajaj Orders",
        "entity_type": "vehicle_order",
        "trigger": "BEFORE_SUBMIT",
        "priority": 21,
        "enabled": true,
        "condition": {
          "op": "IS_NULL",
          "left": {
            "path": "vehicle_order.gstin"
          }
        },
        "action": {
          "type": "BLOCK",
          "message": "GSTIN is required before submitting this Bajaj vehicle order."
        }
      }
    },
    {
      "business_intent": "Sales executives cannot approve vehicle orders above ₹5L.",
      "risk_mitigated": "Prevents high-value approvals by unauthorized sales users.",
      "layer": "role",
      "enforcement_level": "BLOCK",
      "rule_json": {
        "id": "rule.vehicle_order.sales_exec_approval_limit",
        "name": "Sales Executive Approval Limit",
        "entity_type": "vehicle_order",
        "trigger": "BEFORE_APPROVE",
        "priority": 5,
        "enabled": true,
        "condition": {
          "op": "AND",
          "conditions": [
            {
              "op": "GT",
              "left": {
                "path": "vehicle_order.total_amount"
              },
              "right": {
                "value": 500000
              }
            },
            {
              "op": "EQ",
              "left": {
                "path": "session.role"
              },
              "right": {
                "value": "SALES_EXECUTIVE"
              }
            }
          ]
        },
        "action": {
          "type": "BLOCK",
          "message": "Sales Executive cannot approve vehicle orders above ₹5L."
        }
      }
    },
    {
      "business_intent": "Managers should be warned when discount is above recommended limit.",
      "risk_mitigated": "Allows business flexibility while surfacing margin risk.",
      "layer": "platform",
      "enforcement_level": "WARN",
      "rule_json": {
        "id": "rule.vehicle_order.high_discount_warning",
        "name": "High Discount Warning",
        "entity_type": "vehicle_order",
        "trigger": "BEFORE_APPROVE",
        "priority": 20,
        "enabled": true,
        "condition": {
          "op": "GT",
          "left": {
            "path": "vehicle_order.discount_pct"
          },
          "right": {
            "value": 7
          }
        },
        "action": {
          "type": "WARN",
          "message": "Discount of {{vehicle_order.discount_pct}}% exceeds the configured recommended limit."
        }
      }
    },
    {
      "business_intent": "Small vehicle orders can be marked for fast-track review before submission.",
      "risk_mitigated": "Reduces approval effort for low-risk transactions.",
      "layer": "tenant",
      "enforcement_level": "SET_FIELD",
      "rule_json": {
        "id": "rule.vehicle_order.fast_track_small_order",
        "name": "Fast Track Small Order",
        "entity_type": "vehicle_order",
        "trigger": "BEFORE_SUBMIT",
        "priority": 30,
        "enabled": true,
        "condition": {
          "op": "LTE",
          "left": {
            "path": "vehicle_order.total_amount"
          },
          "right": {
            "value": 50000
          }
        },
        "action": {
          "type": "SET_FIELD",
          "field": "fast_track",
          "value": true
        }
      }
    },
    {
      "business_intent": "After approval, start vehicle delivery workflow.",
      "risk_mitigated": "Prevents approved orders from waiting manually for delivery coordination.",
      "layer": "vertical",
      "enforcement_level": "START_WORKFLOW",
      "rule_json": {
        "id": "rule.vehicle_order.start_delivery_workflow",
        "name": "Start Delivery Workflow After Approval",
        "entity_type": "vehicle_order",
