  "workflows": [
    {
      "artifact_key": "workflow.vehicle_order",
      "entity_type": "vehicle_order",
      "name": "Vehicle Order Workflow",
      "initial_state": "DRAFT",
      "states": [
        {
          "state": "DRAFT",
          "label": "Draft",
          "type": "normal",
          "source_layer": "platform"
        },
        {
          "state": "SUBMITTED",
          "label": "Submitted",
          "type": "normal",
          "source_layer": "platform"
        },
        {
          "state": "SALES_MANAGER_REVIEW",
          "label": "Sales Manager Review",
          "type": "normal",
          "source_layer": "tenant"
        },
        {
          "state": "APPROVED",
          "label": "Approved",
          "type": "normal",
          "source_layer": "platform"
        },
        {
          "state": "REJECTED",
          "label": "Rejected",
          "type": "terminal",
          "source_layer": "platform"
        },
        {
          "state": "CANCELLED",
          "label": "Cancelled",
          "type": "terminal",
          "source_layer": "platform"
        },
        {
          "state": "DELIVERED",
          "label": "Delivered",
          "type": "terminal",
          "source_layer": "vertical"
        }
      ],
      "transitions": [
        {
          "id": "tr.submit",
          "from": "DRAFT",
          "to": "SUBMITTED",
          "command": "SUBMIT",
          "actor_roles": [
            "SALES_EXECUTIVE",
            "SALES_MANAGER"
          ],
          "before_trigger": "BEFORE_SUBMIT",
          "after_trigger": "AFTER_SUBMIT",
          "guard_rules": [
            "rule.vehicle_order.min_lines",
            "rule.vehicle_order.vehicle_model_required",
            "rule.vehicle_order.bajaj_dealer_code_required",
            "rule.vehicle_order.gstin_required"
          ],
          "source_layer": "platform"
        },
        {
          "id": "tr.manager_review",
          "from": "SUBMITTED",
          "to": "SALES_MANAGER_REVIEW",
          "command": "ROUTE_TO_MANAGER",
          "actor_roles": [
            "SALES_MANAGER"
          ],
          "before_trigger": "BEFORE_APPROVE",
          "guard_rules": [
            "rule.vehicle_order.high_discount_warning"
          ],
          "source_layer": "tenant"
        },
        {
          "id": "tr.approve",
          "from": "SUBMITTED",
          "to": "APPROVED",
          "command": "APPROVE",
          "actor_roles": [
            "SALES_MANAGER",
            "DEALER_PRINCIPAL",
            "OEM_ADMIN"
          ],
          "before_trigger": "BEFORE_APPROVE",
          "after_trigger": "AFTER_APPROVE",
          "guard_rules": [
            "rule.vehicle_order.sales_exec_approval_limit"
          ],
          "source_layer": "platform"
        },
        {
          "id": "tr.manager_approve",
          "from": "SALES_MANAGER_REVIEW",
          "to": "APPROVED",
          "command": "APPROVE",
          "actor_roles": [
            "SALES_MANAGER",
            "DEALER_PRINCIPAL"
          ],
          "before_trigger": "BEFORE_APPROVE",
          "after_trigger": "AFTER_APPROVE",
          "guard_rules": [
            "rule.vehicle_order.high_discount_warning"
          ],
          "source_layer": "tenant"
        },
        {
          "id": "tr.reject",
          "from": "SUBMITTED",
          "to": "REJECTED",
          "command": "REJECT",
          "actor_roles": [
            "SALES_MANAGER",
            "DEALER_PRINCIPAL"
          ],
          "before_trigger": "BEFORE_UPDATE",
          "source_layer": "platform"
        },
        {
          "id": "tr.cancel",
          "from": "DRAFT",
          "to": "CANCELLED",
          "command": "CANCEL",
          "actor_roles": [
            "SALES_EXECUTIVE",
            "SALES_MANAGER"
          ],
          "before_trigger": "BEFORE_CANCEL",
          "source_layer": "platform"
        },
        {
          "id": "tr.deliver",
          "from": "APPROVED",
          "to": "DELIVERED",
          "command": "MARK_DELIVERED",
          "actor_roles": [
            "SALES_MANAGER",
            "DEALER_PRINCIPAL"
          ],
          "before_trigger": "BEFORE_UPDATE",
          "source_layer": "vertical"
        }
      ],
      "validation_findings": [
        {
          "severity": "warning",
